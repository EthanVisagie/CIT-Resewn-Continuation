{
  "schemaVersion": 1,
  "id": "citresewn",
  "version": "${mod_version}",
  "name": "CIT Resewn Continuation",
  "description": "Unofficial continuation of CIT Resewn for modern Fabric versions",
  "authors": [
    "SHsuperCM"
  ],
  "license": "MIT",
  "icon": "assets/citresewn/logo.png",
  "contact": {
    "homepage": "https://github.com/EthanVisagie/CIT-Resewn-Continuation",
    "sources": "https://github.com/EthanVisagie/CIT-Resewn-Continuation",
    "issues": "https://github.com/EthanVisagie/CIT-Resewn-Continuation/issues"
  },

  "environment": "client",
  "accessWidener" : "citresewn.accesswidener",
  "entrypoints": {
    "client": [
      "shcm.shsupercm.fabric.citresewn.CITResewn"
    ],
    "modmenu": [
      "shcm.shsupercm.fabric.citresewn.config.CITResewnModMenu"
    ]
  },
  "mixins": [
    "citresewn.mixins.json"
  ],
  "depends": {
    "fabric": "*",
    "fabricloader": "*",
    "minecraft": "${mod_target_mc}"
  },
  "recommends": {
    "modmenu": "*",
    "cloth-config2": "*"
  },
  "breaks": {
    "canvas": "*"
  }
}
